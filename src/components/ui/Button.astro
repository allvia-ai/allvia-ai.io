---
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-medium rounded-md border transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#a5b4fc] no-underline';

const variantClasses = {
  primary: 'bg-[#a5b4fc] border-[#a5b4fc] text-[#111214] !text-[#111214] hover:bg-[#c7d2fe] hover:border-[#c7d2fe] active:bg-accent-200',
  secondary: 'bg-[#16181d] border-white/15 text-neutral-100 hover:bg-[#1b1d23] hover:border-white/25',
  ghost: 'bg-transparent border-transparent text-neutral-400 hover:text-neutral-100 hover:bg-white/5',
};

const sizeClasses = {
  sm: 'px-3 py-1.5 text-xs gap-1.5',
  md: 'px-4 py-2 text-sm gap-2',
  lg: 'px-5 py-2.5 text-sm gap-2',
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].filter(Boolean).join(' ');

const basePathRaw = import.meta.env.BASE_URL ?? '/';
const normalizedBasePath = basePathRaw.endsWith('/') ? basePathRaw : `${basePathRaw}/`;
const basePrefix = normalizedBasePath === '/' ? '' : normalizedBasePath.slice(0, -1);

const isExternalHref = (url: string) =>
  url.startsWith('http://') ||
  url.startsWith('https://') ||
  url.startsWith('mailto:') ||
  url.startsWith('tel:') ||
  url.startsWith('#') ||
  url.startsWith('//');

const withBase = (url: string) => {
  if (!url || isExternalHref(url) || !url.startsWith('/')) return url;
  if (!basePrefix) return url;
  if (url === basePrefix || url.startsWith(`${basePrefix}/`)) return url;
  return `${basePrefix}${url}`;
};

const resolvedHref = href ? withBase(href) : undefined;
---

{href ? (
  <a href={resolvedHref} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
